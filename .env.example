# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8018
WEB_PORT=3008

# API / bridge ports
API_PORT=8018
DEEPTUTOR_BRIDGE_PORT=8121

# External repo discovery paths
DEEPTUTOR_EXTERNAL_PATH=/tmp/008-discovery/DeepTutor
GPT_RESEARCHER_EXTERNAL_PATH=/tmp/008-discovery/gpt-researcher

# Config file overrides
LLM_CONFIG_PATH=~/tools/from-obsidian/AI/config/century.json
LLM_CONFIG_PROFILE=dashscope
EMBEDDING_CONFIG_PROFILE=dashscope_embedding
FASTGPT_CONFIG_PATH=~/tools/from-obsidian/AI/config/gbcs-fast.json

# Optional direct overrides (env > file)
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
# FASTGPT_BASE_URL=
# FASTGPT_API_KEY=
# FASTGPT_SEARCH_API_KEY=

# Service wiring
DEEPTUTOR_BASE_URL=http://127.0.0.1:8121

# FastGPT advanced verification
# FASTGPT_VERIFICATION_DATASET_ID=6984435295a6ce02e80696a1
# FASTGPT_VERIFICATION_COLLECTION_ID=

# GPT Researcher tuning
GPT_RESEARCHER_RETRIEVER=duckduckgo
GPT_RESEARCHER_MAX_ITERATIONS=2
