{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvaluationNotesMeta",
  "type": "object",
  "required": [
    "purpose",
    "primary_checks",
    "known_limitations"
  ],
  "properties": {
    "purpose": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "primary_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_review_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
