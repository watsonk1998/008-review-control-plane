{
  "id": "execution_risk_reviewer",
  "agent_name": "通用技术风险审查",
  "agent_purpose": "识别方案执行层面的系统性风险、逻辑链路断点与资源协调缺口",
  "agent_scope": "execution_continuity",
  "execution_mode": "hermes_router",
  "module_bindings": [
    "fact_extract"
  ],
  "supported_document_types": [],
  "focus_keywords": [
    "风险",
    "实施",
    "逻辑",
    "链路",
    "连贯性",
    "节点",
    "顺序",
    "工序"
  ],
  "required_context_types": [
    "target_document",
    "focus_requirements"
  ],
  "input_contract": {
    "type": "review_brief"
  },
  "output_contract": {
    "type": "fact_packet",
    "role": "supplemental"
  },
  "instructions": "审查方案技术方案的执行风险：识别工序逻辑断点、关键节点紧张度、资源协调缺口和系统性遗漏问题。不审查参数一致性（由 parameter_consistency_reviewer 负责）。",
  "prompt": "请识别此方案在技术方案执行层面的系统性风险、工序逻辑问题和资源协调缺口。",
  "default_enabled": true,
  "save_policy": {
    "seed": true
  },
  "template_version": "1.0.0",
  "compatibility": {
    "controller": "hermes_v0"
  },
  "metadata": {
    "review_modules": [
      "execution_continuity"
    ],
    "ownership": "hermes_main_review"
  },
  "input_token_limit": 200000,
  "output_token_limit": 200000
}
