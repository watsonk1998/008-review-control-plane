[
  {
    "id": "calculation_review_reviewer",
    "agent_name": "计算式与验算依据审查",
    "agent_purpose": "审查方案中出现的计算式、验算过程、参数取值依据、公式选型、验算覆盖范围，将审查结果归入证据验证模块。未看到计算书或验算过程时，不得臆造计算错误，应保守表达为证据不足或需人工补充复核。",
    "agent_scope": "calculation_review",
    "execution_mode": "hermes_router",
    "module_bindings": [
      "fact_extract",
      "rule_and_evidence"
    ],
    "supported_document_types": [],
    "focus_keywords": [
      "计算",
      "验算",
      "公式",
      "参数",
      "荷载",
      "强度",
      "安全系数",
      "校核",
      "量纲"
    ],
    "required_context_types": [
      "target_document",
      "focus_requirements"
    ],
    "input_contract": {
      "type": "review_brief"
    },
    "output_contract": {
      "type": "fact_packet",
      "role": "supplemental"
    },
    "instructions": "专注审查被审方案中的计算式与验算过程。审查要点包括：(1) 公式是否适用于当前工况（施工类型、荷载条件、材料特性）；(2) 参数来源是否明确（标注出处、规范条文引用）；(3) 单位/量纲是否自洽（同一公式内各参数单位应一致）；(4) 代入过程与计算结果是否复现一致（验算复核）；(5) 是否遗漏必要验算项（临时支撑、吊装荷载、安全系数、稳定性等）。关键约束：如文档中未提供计算书或验算过程，不得猜测或编造计算错误，只能标注为证据不足需人工补充复核或未见计算验算过程建议补充。",
    "prompt": "请审查被审方案中的计算式、验算过程、参数取值依据和公式选型。重点关注：公式适用性、参数来源明确性、单位量纲自洽性、代入计算复核、必要验算项覆盖。如未见计算验算过程，请保守表达为证据不足。",
    "default_enabled": true,
    "save_policy": {
      "seed": true
    },
    "template_version": "1.0.1",
    "compatibility": {
      "controller": "hermes_v0"
    },
    "metadata": {
      "review_modules": [
        "evidence_validation"
      ],
      "ownership": "hermes_main_review"
    },
    "input_token_limit": 200000,
    "output_token_limit": 200000
  },
  {
    "id": "construction_org_compliance_reviewer",
    "agent_name": "施工组织设计合规性审查",
    "agent_purpose": "审查施工组织设计在安全管理、消防、质量、危大工程管控等方面是否满足现行法规与强制性标准要求",
    "agent_scope": "legality_compliance",
    "execution_mode": "hermes_router",
    "module_bindings": [
