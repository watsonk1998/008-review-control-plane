  {
    "id": "construction_org_technical_reviewer",
    "agent_name": "施工组织设计技术方案审查",
    "agent_purpose": "审查施工组织设计的技术方案合理性，包括施工方法可行性、工序逻辑、危大工程管控、季节性措施和应急预案",
    "agent_scope": "execution_continuity",
    "execution_mode": "hermes_router",
    "module_bindings": [
      "fact_extract",
      "rule_and_evidence"
    ],
    "supported_document_types": [
      "construction_org"
    ],
    "focus_keywords": [
      "施工方法",
      "主要施工方案",
      "施工工艺",
      "工序",
      "施工顺序",
      "施工流程",
      "危险性较大",
      "危大工程",
      "专项施工方案",
