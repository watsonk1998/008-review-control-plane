    "supported_document_types": [
      "construction_org"
    ],
    "focus_keywords": [
      "安全管理",
      "安全生产",
      "消防",
      "防火",
      "质量管理",
      "危险性较大",
      "危大工程",
      "重大事故隐患",
      "专项方案",
      "应急预案",
      "文明施工",
      "安全教育培训",
      "安全技术措施",
      "扬尘控制",
      "临时用电",
      "脚手架",
      "起重吊装"
