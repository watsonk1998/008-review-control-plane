{
  "name": "hermes-fastgpt-integration",
  "private": true,
  "type": "module",
  "scripts": {
    "export:assets": "python3 ./scripts/export_governed_assets.py",
    "generate:workflow": "node ./scripts/generate_workflow.mjs",
    "generate:parity": "node ./scripts/generate_parity_matrix.mjs",
    "diagnose:quality": "node ./scripts/generate_quality_diagnostics.mjs",
    "generate:all": "npm run export:assets && npm run generate:workflow && npm run link:local && npm run generate:parity",
    "build:delivery": "node ./scripts/build_delivery_package.mjs",
    "acceptance:real-docx": "node ./scripts/run_real_scheme_acceptance.mjs",
    "test": "vitest run",
    "link:workflow": "node ./scripts/apply_runtime_overrides.mjs",
    "link:local": "node ./scripts/apply_runtime_overrides.mjs ../../artifacts/fastgpt/workflow_tool_registry.local.json",
    "validate:bundle": "npm run generate:all",
    "legacy:build-pkg": "bash ./scripts/build_fastgpt_pkg.sh"
  },
  "dependencies": {
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "description": "FastGPT 主工作流与工作流工具迁移 bundle for hermes-review-agent"
}
